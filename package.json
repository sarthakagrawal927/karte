{
  "name": "linkchat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-reporter=spec 'tests/**/*.unit.test.mjs'",
    "smoke:agent": "node scripts/smoke-agent-api.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "backfill:aggregates": "node scripts/backfill-aggregates.mjs",
    "enrich:profile": "node scripts/enrich-profile-from-links.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:build": "next build --webpack && node scripts/inline-critical-css.mjs && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare populateCache local && pnpm --filter ./landing-astro build && node scripts/overlay-astro-landing.mjs",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload:cf": "opennextjs-cloudflare build && opennextjs-cloudflare upload"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.41",
    "@better-fetch/fetch": "1.1.21",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@libsql/client": "0.17.3",
    "@opennextjs/cloudflare": "1.19.4",
    "@types/sanitize-html": "^2.16.1",
    "ai": "6.0.168",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "html-to-image": "1.11.13",
    "motion": "^12.40.0",
    "next": "16.2.4",
    "novel": "1.0.2",
    "posthog-js": "^1.372.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@saas-maker/eslint-config": "^1.0.5",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "babel-plugin-react-compiler": "1.0.0",
    "beasties": "^0.4.2",
    "critters": "^0.0.25",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "4",
    "typescript": "6.0.3",
    "wrangler": "4.85.0"
  }
}
