/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Cache the HTML at the CF edge for ~1 day; stale-while-revalidate keeps it
# instant for everyone while a single deploy bumps the source-of-truth.
# psi-swarm flagged TTFB as the dominant LCP contributor on the Next.js
# build; long s-maxage + browser max-age is the fix.
#
# Explicit max-age (browser cache) is the tell CF Pages needs to mark
# HTML responses as cacheable at edge too — without it, responses come
# back as cf-cache-status: DYNAMIC.
/
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

/*.html
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800
