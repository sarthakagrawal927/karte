---
// Self-hosted variable fonts. Astro inlines the @font-face into the
// page's CSS via Lightning CSS (build.inlineStylesheets: 'always'),
// so we drop the external fonts.googleapis.com round-trip from the
// LCP path. Family names register as 'Playfair Display Variable' and
// 'Inter Variable' — mapped onto the existing --font-* CSS vars below
// so landing.css needs no changes. Playfair italic is required by
// the deck (.onyx-screen-title, .onyx-quote, etc.).
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/playfair-display/wght-italic.css';
import '@fontsource-variable/inter';
import '@/styles/landing.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://karte.cc';
// OG/Twitter image lives on the Next.js Worker at /opengraph-image
// (Next file convention → dynamic JSX → PNG). Astro can't trivially
// reproduce that. Post-cutover Pages takes `/` and Workers keeps every
// other route, so this URL still resolves. See README → cutover notes.
const OG_IMAGE = `${SITE_URL}/opengraph-image`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="Karte" />

    <link rel="canonical" href={SITE_URL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="Karte" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <meta name="keywords" content="link in bio, personal website, digital card, Linktree alternative" />

    {/* SoftwareApplication structured data — helps search engines
        understand Karte is a free web app built by Sarthak Agrawal. */}
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Karte',
      applicationCategory: 'WebApplication',
      operatingSystem: 'Web Browser',
      url: 'https://karte.cc',
      description:
        'Link-in-bio platform with AI-enhanced profile modes — chat, encyclopedia, roast, and newspaper — that transform how visitors interact with your profile.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      creator: {
        '@type': 'Person',
        name: 'Sarthak Agrawal',
        url: 'https://sarthakagrawal.dev',
      },
    })} />

    {/* Wire the same CSS vars Next.js's next/font set up, so landing.css
       (which references var(--font-playfair) / var(--font-inter)) keeps
       working without changes. Fontsource Variable registers families
       as 'Playfair Display Variable' / 'Inter Variable', with the
       plain names left in the fallback chain so any cached non-variable
       face still hits before the system fallback. Geist/Instrument
       Serif/JetBrains were never loaded on this surface — kept as
       fallback-only var values to match the original Next.js layout. */}
    <style is:inline>
      :root {
        --font-playfair: 'Playfair Display Variable', 'Playfair Display', Georgia, 'Times New Roman', serif;
        --font-inter: 'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif;
        --font-instrument-serif: 'Instrument Serif', Georgia, serif;
        --font-geist-sans: 'Geist', system-ui, sans-serif;
        --font-geist-mono: 'Geist Mono', ui-monospace, monospace;
        --font-jetbrains: 'JetBrains Mono', ui-monospace, monospace;
      }
      html.dark { color-scheme: dark; }
      body { margin: 0; }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
