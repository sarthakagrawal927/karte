---
// The card frame for the Onyx landing deck.
//
// Each section of the landing page is rendered as one of these cards.
// The frame supplies: gold foil border (via mask-composite), corner
// ◆ glyphs, three-column header (mark / kicker / serial), the body
// slot (via Astro <slot />), and a footer strip with left/right
// content separated by a gradient hairline rule.
//
// Astro port of /src/components/landing/onyx-card.tsx. The original
// React version tracked the cursor in JS to drive the --mx/--my CSS
// vars for a mouse-following sheen overlay. We drop that here — the
// CSS defaults (--mx: 50%, --my: 50%) sit the sheen at center, which
// is also what touch / no-hover devices see in the React version.
// Zero-JS port → faster LCP, identical first paint.

interface Props {
  idx: string; // e.g. "i" — appears as "card i / vi"
  serial: string; // e.g. "№ 00471" — header right
  kicker: string; // e.g. "DIGITAL CARD · CARD V2026" — header centered
  footL: string;
  footR: string;
}

const { idx, serial, kicker, footL, footR } = Astro.props;
---

<div class="onyx-screen" style="--mx: 50%; --my: 50%;">
  <div class="onyx-screen-sheen"></div>
  <div class="onyx-screen-foil"></div>
  <div class="onyx-screen-corner tl" aria-hidden="true">◆</div>
  <div class="onyx-screen-corner tr" aria-hidden="true">◆</div>
  <div class="onyx-screen-corner bl" aria-hidden="true">◆</div>
  <div class="onyx-screen-corner br" aria-hidden="true">◆</div>

  <header class="onyx-screen-head">
    <div class="onyx-screen-mark">
      <span class="onyx-screen-diamond" aria-hidden="true">◆</span>
      <span class="onyx-screen-brand">Karte</span>
    </div>
    <div class="onyx-screen-kicker">{kicker}</div>
    <div class="onyx-screen-serial">{serial}</div>
  </header>

  <div class="onyx-screen-body">
    <slot />
  </div>

  <footer class="onyx-screen-foot">
    <span>{footL}</span>
    <span class="onyx-screen-rule" aria-hidden="true"></span>
    <span>{footR}</span>
  </footer>

  <div class="onyx-screen-idx" aria-hidden="true">card {idx} / vi</div>
</div>
