---
// Card VI — Final CTA.
//
// Astro port of /src/components/landing/onyx-cta.tsx.
//
// The React original used `useRouter().push(`/create?slug=...`)`. Here
// we let the browser do the navigation natively: <form action="/create"
// method="GET"> with <input name="slug"> produces exactly the same URL
// the React version constructed (`/create?slug=foo`). Zero JS.
//
// Compromise: the React onChange that lowercased + stripped non-slug
// characters as the user typed is lost. /create already re-validates
// the slug server-side, so the worst case is a slightly uglier
// query string before /create normalises it. Acceptable trade.
---

<div class="onyx-cta">
  <div class="onyx-eyebrow center">·  CLAIM YOUR NAME  ·</div>
  <h2 class="onyx-cta-h">
    Build the profile
    <br />
    <em>they talk to.</em>
  </h2>
  <p class="onyx-cta-sub">
    One link. Four surfaces. Conversations that travel. Free forever.
  </p>
  <form class="onyx-cta-form" action="/create" method="GET">
    <span class="onyx-cta-prefix">karte.cc /</span>
    <input
      class="onyx-cta-input"
      aria-label="Your Karte handle"
      name="slug"
      placeholder="yourname"
      maxlength="40"
      pattern="[a-z0-9\-]{1,40}"
      autocapitalize="off"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    />
    <button type="submit" class="onyx-btn-primary">
      Claim <span aria-hidden="true">→</span>
    </button>
  </form>
  <div class="onyx-cta-fine">
    Free · no card · 60-second import.
  </div>
</div>
