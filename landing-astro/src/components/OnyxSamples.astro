---
// Card V — The Members: sample profiles built from public writing.
//
// Astro port of /src/components/landing/onyx-samples.tsx. PostHog
// click capture dropped (see Layout / README — no analytics on the
// static landing port).
const SAMPLES = [
  { slug: 'naval',    label: 'Naval',        flavor: 'On wealth, leverage, long-term games.' },
  { slug: 'levelsio', label: 'levelsio',     flavor: 'Solo builder. Public MRR. Lisbon-based.' },
  { slug: 'pg',       label: 'Paul Graham',  flavor: 'YC. Essays. Default-alive.' },
  { slug: 'karpathy', label: 'Karpathy',     flavor: 'Back at OpenAI. Eureka Labs.' },
] as const;
---

<div class="onyx-samples">
  <div class="onyx-eyebrow center">·  THE MEMBERS  ·</div>
  <h2 class="onyx-h2 center">
    See it on a{' '}
    <em>real profile.</em>
  </h2>
  <p class="onyx-samples-sub">
    Four sample cards built from public writing. Open one and talk to it —
    ask what they charge, where they live, what stack they use.
  </p>

  <ul class="onyx-samples-list">
    {SAMPLES.map((s) => (
      <li>
        <a href={`/${s.slug}`} class="onyx-samples-link">
          <span class="onyx-samples-name">{s.label}</span>
          <span class="onyx-samples-flavor">{s.flavor}</span>
          <span class="onyx-samples-arrow" aria-hidden="true">
            karte.cc / {s.slug} →
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
